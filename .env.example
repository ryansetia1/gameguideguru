TAVILY_API_KEY=tvly-your-key
# Optional: Serper.dev is used as a fallback when Tavily is down or over quota.
SERPER_API_KEY=your-serper-key
REPLICATE_API_TOKEN=r8_your-token
# Optional: any public Replicate model in owner/name format.
REPLICATE_MODEL=google/gemini-2.5-flash
# Optional: enables game-name autocomplete + box art via TheGamesDB.
# Request an API key from your https://thegamesdb.net account.
THEGAMESDB_API_KEY=your-thegamesdb-key
# Optional: Steam Web API key for owned-games library import after Steam OpenID login.
# Get one at https://steamcommunity.com/dev/apikey — user's Game details must be Public.
STEAM_API_KEY=your-steam-web-api-key
# Optional: pins OpenID realm/return_to in production (defaults to VERCEL_URL).
# Leave unset for local dev — only needed on Vercel/production.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Optional: extra allowed origins for auth redirects (comma-separated).
# AUTH_ALLOWED_ORIGINS=https://www.your-domain.com
# Optional: signs the Steam session cookie. Falls back to STEAM_API_KEY when unset.
# AUTH_SECRET=your-random-secret
# Optional: log each LLM call to public.llm_calls (run db/llm-calls.sql first).
# On when Supabase vars are set; set LLM_DB_LOG=0 to disable.
# LLM_DB_LOG=0
# Optional: enables accounts, saved per-game chats, and the shared web-search
# cache via Supabase. Safe to expose (protected by row-level security).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key
# Optional: enables "Sign in with Steam" (mints a Supabase account for the Steam
# identity). Server-only — NEVER expose via NEXT_PUBLIC. Without it Steam stays a
# link-only action on a Google/email account. Find it in Supabase > Project
# Settings > API > service_role.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


